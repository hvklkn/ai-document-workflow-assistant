# ── Backend ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database ─────────────────────────────────────────────────
# Get this from Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional: change to gpt-3.5-turbo to reduce costs during development
OPENAI_MODEL=gpt-4o

# ── n8n Webhook ──────────────────────────────────────────────
# Paste your n8n webhook URL here (from the Webhook node in your n8n workflow)
# Leave blank to disable webhook triggering
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/YOUR-WEBHOOK-ID
